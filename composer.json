{
  "name": "placetopay/magento2-module-payments",
  "description": "Shared component for accepting online payments in Magento 2 using the PlacetoPay payment gateway.",
  "type": "magento2-module",
  "license": [
    "OSL-3.0",
    "AFL-3.0"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.magento.com/"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-json": "*"
  },
  "require-dev": {
    "magento/magento-coding-standard": "*",
    "magento/framework": "^103.0.4",
    "magento/module-vault": "^101.2.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
    "phpcompatibility/php-compatibility": "^9.3"
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "PlacetoPay\\Payments\\": ""
    }
  },
  "scripts": {
    "post-install-cmd": [
      "([ $COMPOSER_DEV_MODE -eq 0 ] || vendor/bin/phpcs --config-set installed_paths ../../magento/magento-coding-standard/)"
    ],
    "post-update-cmd": [
      "([ $COMPOSER_DEV_MODE -eq 0 ] || vendor/bin/phpcs --config-set installed_paths ../../magento/magento-coding-standard/)"
    ],
    "phpcs:compat": "vendor/bin/phpcs -p --standard=PHPCompatibility --runtime-set testVersion 7.4-8.4 --ignore=vendor/* ."
  },
  "config": {
    "allow-plugins": {
      "magento/composer-dependency-version-audit-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
